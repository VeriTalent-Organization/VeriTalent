# =============================================================================
# VeriTalent AI - Docker Environment Template
# =============================================================================
# Copy this file to .env in the project root and fill in your credentials
# Usage: docker-compose --env-file .env.local up -d

# -----------------------------------------------------------------------------
# Azure AI Configuration (REQUIRED)
# -----------------------------------------------------------------------------
AZURE_AI_ENDPOINT=https://verdiaq-ai-resource.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
AZURE_AI_API_KEY=your-azure-api-key-here
AZURE_AI_MODEL=grok-4-fast-reasoning

# Azure OpenAI Embeddings (Separate endpoint)
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://verdiaq-ai-resource.cognitiveservices.azure.com/openai/deployments/text-embedding-3-small/embeddings?api-version=2023-05-15
AZURE_OPENAI_EMBEDDING_KEY=your-azure-openai-key-here
AZURE_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# MongoDB Atlas (Vector Database)
# -----------------------------------------------------------------------------
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DATABASE_NAME=veritalent_ai
MONGODB_VECTORS_COLLECTION=embeddings

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
AI_API_DEBUG=false
AI_API_KEY=your-production-api-key-here

# -----------------------------------------------------------------------------
# Backend Integration
# -----------------------------------------------------------------------------
BACKEND_API_URL=https://veritalent-server.onrender.com/v1
AI_SERVICE_URL=http://veritalent-ai:8080

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-secure-random-string
ALLOWED_ORIGINS=https://veritalent.com,https://app.veritalent.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Limits
# -----------------------------------------------------------------------------
MAX_CV_SIZE_MB=10
MAX_TOKENS_PER_REQUEST=4000
